{
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "pnpm --filter agent-eval-opencode build",
		"build:agent-eval": "pnpm --filter agent-eval-opencode build",
		"test": "pnpm --filter agent-eval-opencode test",
		"test:watch": "pnpm --filter agent-eval-opencode test:watch",
		"test:integration": "pnpm --filter agent-eval-opencode test:integration",
		"lint": "pnpm --filter agent-eval-opencode lint",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8"
	}
}
